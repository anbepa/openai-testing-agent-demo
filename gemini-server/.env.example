# Google API Key for Gemini
GOOGLE_API_KEY=your_google_api_key_here

# Server Configuration
PORT=8000
CORS_ORIGIN=*

# Integration Mode
# Set to 'true' to use legacy Gemini CLI (deprecated)
USE_GEMINI_CLI=false

# Set to 'true' to use new Gemini CLI + MCP integration (recommended)
USE_MCP_INTEGRATION=true